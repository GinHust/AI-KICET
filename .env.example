# ── Thông tin chung ─────────────────────────────────────────────────────
KICETIC_APP_NAME=KICETIC
KICETIC_APP_ENV=development

# ── API Base URL (Quan trọng) ───────────────────────────────────────────
# Local (backend chạy port 8005)
NEXT_PUBLIC_KICETIC_API_BASE_URL=http://127.0.0.1:8005

# Khi deploy lên Cloud Run thì uncomment dòng dưới và comment dòng trên
# NEXT_PUBLIC_KICETIC_API_BASE_URL=https://kicetic-api-909376211423.asia-northeast3.run.app

# ── API Keys (BẮT BUỘC phải có) ───────────────────────────────────────
KICETIC_ANTHROPIC_API_KEY=sk-ant-....................................
# KICETIC_OPENAI_API_KEY=sk-..........................................   # optional

# ── CORS (Local thường không cần, Cloud thì nên có) ───────────────────
# KICETIC_CORS_ORIGINS=["https://kicetic.vercel.app","http://localhost:3000"]

# ── Database Optuna / Study ────────────────────────────────────────────
KICETIC_MPCVD_STUDY_NAME=mpcvd_optimization_v2

# Local thì không cần set KICETIC_DATABASE_URL (sẽ tự dùng SQLite)
# Cloud / Production thì uncomment và điền Supabase URL
# KICETIC_DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-xxx.pooler.supabase.com:5432/postgres

# ── Chế độ Module ───────────────────────────────────────────────────────
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_KICETIC_DATA_MODE=real

KICETIC_PROJECTS_BACKEND=real
KICETIC_DISCUSSIONS_BACKEND=real
KICETIC_OPTIMIZER_BACKEND=real
KICETIC_XAI_BACKEND=mock          # hiện tại đang mock, sau có thể đổi thành real
