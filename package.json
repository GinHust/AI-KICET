{
  "name": "kicetic",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @kicetic/web",
    "dev:web": "npm run dev --workspace @kicetic/web",
    "dev:api": "python -m uvicorn app.main:app --app-dir apps/api --host 127.0.0.1 --port 8005 --reload",
    "start:windows": "start-dev.bat",
    "lint": "npm run lint --workspace @kicetic/web",
    "typecheck": "npx tsc --noEmit -p apps/web/tsconfig.json",
    "test:e2e": "playwright test"
  }
}
