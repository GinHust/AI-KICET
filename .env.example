# ── 공통 ──────────────────────────────────────────────────────────────────────
KICETIC_APP_NAME=KICETIC
KICETIC_APP_ENV=development

# ── API 주소 (프론트엔드용) ────────────────────────────────────────────────────
# 로컬
NEXT_PUBLIC_KICETIC_API_BASE_URL=http://127.0.0.1:8004
# 배포 후 Cloud Run URL로 교체
# NEXT_PUBLIC_KICETIC_API_BASE_URL=https://kicetic-api-xxxxxxxxxx-an.a.run.app

# ── CORS (배포 후 Vercel URL 추가) ────────────────────────────────────────────
# 로컬 기본값은 config.py에 내장. 클라우드에서는 JSON 배열로 덮어씀
# KICETIC_CORS_ORIGINS=["https://kicetic.vercel.app","https://your-custom-domain.com"]

# ── Optuna DB ─────────────────────────────────────────────────────────────────
# 로컬: 미설정 시 apps/api/app/data/mpcvd_study_v2.db (SQLite) 자동 사용
# 클라우드: Supabase PostgreSQL URL 입력
# KICETIC_DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

KICETIC_MPCVD_STUDY_NAME=mpcvd_optimization_v2

# ── 모듈 모드 ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_USE_MOCK=false
NEXT_PUBLIC_KICETIC_DATA_MODE=real
KICETIC_PROJECTS_BACKEND=real
KICETIC_DISCUSSIONS_BACKEND=real
KICETIC_OPTIMIZER_BACKEND=real
KICETIC_XAI_BACKEND=mock
